# Azure AI Foundry Project endpoint
# Format: https://<your-ai-services-account>.services.ai.azure.com/api/projects/<your-project-name>
# Found in: Azure AI Foundry portal > Project > Overview > Project endpoint
FOUNDRY_PROJECT_ENDPOINT=https://<your-ai-services-account>.services.ai.azure.com/api/projects/<your-project-name>

# Model deployment name (e.g., gpt-4o, gpt-4o-mini)
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o

# AI Search connection name as registered in your Foundry project
# Found in: Azure AI Foundry portal > Project > Settings > Connected resources
AZURE_AI_SEARCH_CONNECTION_NAME=<your-search-connection-name>

# AI Search index name to query
AI_SEARCH_INDEX_NAME=<your-index-name>
