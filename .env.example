# ============================================================
# Azure AI Foundry - simpleagent Demo Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it contains secrets.

# ──────────────────────────────────────────────────────────────
# NEW FOUNDRY (Responses API) — ai.azure.com portal
# Uses: azure-ai-projects >= 2.0.0
# ──────────────────────────────────────────────────────────────

# Full project endpoint — found in AI Foundry portal > Project > Overview
# Format: https://<ai-services-name>.services.ai.azure.com/api/projects/<project-name>
# VNet demo value: https://clark-simpleagent-vnet.services.ai.azure.com/api/projects/<project-name>
# Note: Create project at ai.azure.com after connecting to the VNet
FOUNDRY_PROJECT_ENDPOINT=https://clark-simpleagent-vnet.services.ai.azure.com/api/projects/<your-project-name>

# Model deployment name
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o

# AI Search connection name as registered in your Foundry project
# Found in: AI Foundry portal > Project > Settings > Connected resources
# Register the search service as a connection named "clark-search-vnet"
AZURE_AI_SEARCH_CONNECTION_NAME=clark-search-vnet

# AI Search index name
AI_SEARCH_INDEX_NAME=simpleagent-repo-index

# ──────────────────────────────────────────────────────────────
# CLASSIC FOUNDRY (Assistants API) — ml.azure.com portal
# Uses: azure-ai-agents >= 1.0.0
# ──────────────────────────────────────────────────────────────

# Classic hub/project endpoint
# Format: https://eastus.api.azureml.ms
# Found in: Azure ML Studio > your workspace > Settings
CLASSIC_PROJECT_ENDPOINT=https://eastus.api.azureml.ms

# Classic project name (used for display / reference)
CLASSIC_PROJECT_NAME=clark-simpleagent-project
